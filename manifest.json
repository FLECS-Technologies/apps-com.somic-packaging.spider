{
    "$schema": "https://raw.githubusercontent.com/FLECS-Technologies/app-sdk/3.0.0/manifest.schema.json",
    "_schemaVersion": "3.0.0",
    "app": "com.somic-packaging.spider",
    "version": "##VERSION##",
    "revision": "0",
    "image": "flecs.azurecr.io/com.somic-packaging.spider",
    "multiInstance": false,
    "editors": [
        {
            "name": "Somic Spider",
            "port": 5001,
            "supportsReverseProxy": false
        }
    ],
    "args": [
        "--mount type=tmpfs,destination=/mediamtx/recordings,tmpfs-size=1024m,tmpfs-mode=1777"
    ],
    "env": [
        "HOST_IP=127.0.0.1",
        "CAMS_FILE=/data/cams.json",
        "USER_STREAMS=/data/user_streams.json",
        "REQUEST_TIMEOUT=10",
        "DEBUG=false",
        "STREAMS_MAX_PER_CAM=2",
        "CAMS_MAX=10",
        "CONNECTIONS_MAX=20",
        "CLOUD_ACTIVATE=false",
        "CLOUD_API_URL=https://api.somic-packaging.com",
        "CLOUD_API_KEY=12345",
        "HEARTBEAT_INTERVAL=15"
    ],
    "ports": [
        "5001:5001",
        "8554:8554",
        "8888:8888"
    ],
    "volumes": [
        "/home/somic/app/spider/:/data"
    ]
}
